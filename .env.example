# Copy to .env and fill in values

# SQLite for local dev. For production use a hosted DB (e.g. Postgres on Neon/Vercel:
# change provider in prisma/schema.prisma to "postgresql" and set the URL here).
DATABASE_URL="file:./dev.db"

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://compublue.com"

# Secret used to sign admin session tokens - generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Initial admin login (seeded on first `npm run setup`)
ADMIN_EMAIL="admin@compublue.com"
ADMIN_PASSWORD="change-me-strong-password"

# SMTP for lead notification emails (can also be configured in the admin dashboard)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CompuBlue Website <no-reply@compublue.com>"
LEAD_NOTIFY_EMAIL="contact@compublue.com"

# Pexels API key (used by the admin image search and scripts/fetch-images.mjs)
PEXELS_API_KEY="7LcQHqTcBMp1g0RDwdLq22QzcWtjHa5uuGzvXEZ21LAhvKN5sJ0nfcKP"

# Google reCAPTCHA v3 (contact form spam protection).
# Create keys at https://www.google.com/recaptcha/admin (choose reCAPTCHA v3).
# Leave blank to disable verification (form still works via honeypot + rate limit).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# Optional: minimum passing score (0.0–1.0). Defaults to 0.5.
RECAPTCHA_MIN_SCORE="0.5"
